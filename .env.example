# Derivative Backend Configuration
# Copy this file to .env and update the values

# ===================
# DATABASE
# ===================
DATABASE_URL=postgresql://postgres:password@localhost:5432/derivative
DATABASE_MAX_CONNECTIONS=10
DATABASE_MIN_CONNECTIONS=1
DATABASE_CONNECT_TIMEOUT=30
DATABASE_IDLE_TIMEOUT=600

# ===================
# JWT AUTHENTICATION
# ===================
# IMPORTANT: Generate a secure random secret for production!
# Example: openssl rand -base64 64
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_EXPIRY=900          # 15 minutes in seconds
JWT_REFRESH_EXPIRY=1296000     # 15 days in seconds

# ===================
# SERVER
# ===================
SERVER_HOST=0.0.0.0
SERVER_PORT=8081

# ===================
# FILE UPLOADS
# ===================
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760       # 10MB
MAX_AVATAR_SIZE=5242880        # 5MB
MAX_ASSET_SIZE=10485760        # 10MB

# ===================
# CORS
# ===================
CORS_ORIGIN=http://localhost:3000

# ===================
# RATE LIMITING
# ===================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECS=60

# ===================
# LOGGING
# ===================
# Options: trace, debug, info, warn, error
RUST_LOG=info
